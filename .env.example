CELERY_VISIBILITY_TIMEOUT=3600
ANALYSIS_TRACE_ENABLED=true
PARALLEL_READER_ENABLED=false
READER_PARALLELISM=2
READER_BRANCH_RETRIES=1
LLM_INPUT_COST_PER_MILLION_USD=0
LLM_OUTPUT_COST_PER_MILLION_USD=0
LLM_PROVIDER=mock
EMBEDDING_PROVIDER=mock
ASK_CANDIDATE_COUNT=20
ASK_EVIDENCE_COUNT=6
ASK_BM25_K1=1.5
ASK_BM25_B=0.75
ASK_RRF_K=60
ASK_VECTOR_MIN_SIMILARITY=0.0
ASK_INDEX_PREBUILD_ENABLED=true
ASK_INDEX_DIR=backend/outputs/indexes
ASK_RERANKER_MODE=disabled
ASK_RERANKER_PROVIDER=openai_compatible
ASK_RERANKER_MODEL=
