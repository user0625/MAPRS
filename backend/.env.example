# Copy this file to backend/.env and edit the copied file.
# Never commit real API keys.

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=Multi-Agent Paper Reader System
APP_ENV=development
DEBUG=true

# -----------------------------------------------------------------------------
# Default profile: fully offline mock mode
# Valid providers: mock, openai_compatible
# -----------------------------------------------------------------------------
LLM_PROVIDER=mock
LLM_VENDOR=mock
LLM_MODEL=mock-llm
LLM_API_KEY=
LLM_BASE_URL=

EMBEDDING_PROVIDER=mock
EMBEDDING_VENDOR=mock
EMBEDDING_MODEL=mock-embedding
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=

# -----------------------------------------------------------------------------
# Paths (resolved from the repository root)
# -----------------------------------------------------------------------------
DATA_DIR=backend/data
RAW_DATA_DIR=backend/data/raw
PROCESSED_DATA_DIR=backend/data/processed
OUTPUT_DIR=backend/outputs
REPORT_DIR=backend/outputs/reports
LOG_DIR=backend/outputs/logs
DATABASE_URL=sqlite:///backend/data/tasks.db

# Durable task queue defaults for local development
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_MAX_RETRIES=3
CELERY_VISIBILITY_TIMEOUT=3600
TASK_HEARTBEAT_SECONDS=15
TASK_STALE_AFTER_SECONDS=300
CHECKPOINT_SCHEMA_VERSION=1
SSE_HEARTBEAT_SECONDS=15

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
DEFAULT_TOP_K=5
CHUNK_SIZE=1200
CHUNK_OVERLAP=150
PDF_LAYOUT_MODE=auto

# Ask Paper retrieval and optional reranker. Keep disabled until a private
# validation calibration passes and shadow monitoring is complete.
ASK_CANDIDATE_COUNT=20
ASK_EVIDENCE_COUNT=6
ASK_RRF_K=60
ASK_VECTOR_MIN_SIMILARITY=0.0
ASK_RERANKER_MODE=disabled
ASK_RERANKER_PROVIDER=openai_compatible
ASK_RERANKER_MODEL=
ASK_RERANKER_API_KEY=
ASK_RERANKER_BASE_URL=
ASK_RERANKER_TIMEOUT=1.0
ASK_EVIDENCE_THRESHOLD=0.0
ASK_ANSWERABILITY_THRESHOLD=0.0
ASK_CALIBRATION_VERSION=uncalibrated
ASK_REWRITE_MAX_TOKENS=160
ASK_RETRIEVAL_CACHE_SIZE=8

# Shared LLM/Embedding request policy
REQUEST_CONNECT_TIMEOUT=10
REQUEST_READ_TIMEOUT=60
REQUEST_TOTAL_BUDGET=120
REQUEST_MAX_RETRIES=2
REQUEST_BACKOFF_BASE=1
REQUEST_BACKOFF_MAX=8

# Upload, retention and prompt provenance
MAX_UPLOAD_BYTES=52428800
FILE_RETENTION_DAYS=30
PROMPT_SET_VERSION=v1

# Real API tests run only when this value is exactly 1.
RUN_REAL_LLM_TESTS=0

# -----------------------------------------------------------------------------
# Qwen / Alibaba Cloud DashScope profile
# To use it, replace the active LLM and EMBEDDING values above with these values.
# -----------------------------------------------------------------------------
# LLM_PROVIDER=openai_compatible
# LLM_VENDOR=qwen
# LLM_MODEL=qwen-max
# LLM_API_KEY=your_dashscope_api_key_here
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#
# EMBEDDING_PROVIDER=openai_compatible
# EMBEDDING_VENDOR=qwen
# EMBEDDING_MODEL=text-embedding-v4
# EMBEDDING_API_KEY=your_dashscope_api_key_here
# EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# -----------------------------------------------------------------------------
# DeepSeek LLM + mock embedding profile
# DeepSeek is used for chat completion here; retrieval stays offline.
# -----------------------------------------------------------------------------
# LLM_PROVIDER=openai_compatible
# LLM_VENDOR=deepseek
# LLM_MODEL=deepseek-chat
# LLM_API_KEY=your_deepseek_api_key_here
# LLM_BASE_URL=https://api.deepseek.com
#
# EMBEDDING_PROVIDER=mock
# EMBEDDING_VENDOR=mock
# EMBEDDING_MODEL=mock-embedding
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=
# Phase D: long-paper analysis and report quality
HIERARCHICAL_PAGE_THRESHOLD=20
HIERARCHICAL_CHAR_THRESHOLD=60000
VERIFIER_ENABLED=true
QUALITY_PASS_SCORE=75
CITATION_VALIDITY_MIN_SCORE=80
MAX_CUSTOM_SECTIONS=20
