# Copy this file to backend/.env and edit the copied file.
# Never commit real API keys.

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=Multi-Agent Paper Reader System
APP_ENV=development
DEBUG=true

# -----------------------------------------------------------------------------
# Default profile: fully offline mock mode
# Valid providers: mock, openai_compatible
# -----------------------------------------------------------------------------
LLM_PROVIDER=mock
LLM_VENDOR=mock
LLM_MODEL=mock-llm
LLM_API_KEY=
LLM_BASE_URL=

EMBEDDING_PROVIDER=mock
EMBEDDING_VENDOR=mock
EMBEDDING_MODEL=mock-embedding
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=

# -----------------------------------------------------------------------------
# Paths (resolved from the repository root)
# -----------------------------------------------------------------------------
DATA_DIR=backend/data
RAW_DATA_DIR=backend/data/raw
PROCESSED_DATA_DIR=backend/data/processed
OUTPUT_DIR=backend/outputs
REPORT_DIR=backend/outputs/reports
LOG_DIR=backend/outputs/logs
DATABASE_URL=sqlite:///backend/data/tasks.db

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
DEFAULT_TOP_K=5
CHUNK_SIZE=1200
CHUNK_OVERLAP=150

# Real API tests run only when this value is exactly 1.
RUN_REAL_LLM_TESTS=0

# -----------------------------------------------------------------------------
# Qwen / Alibaba Cloud DashScope profile
# To use it, replace the active LLM and EMBEDDING values above with these values.
# -----------------------------------------------------------------------------
# LLM_PROVIDER=openai_compatible
# LLM_VENDOR=qwen
# LLM_MODEL=qwen-max
# LLM_API_KEY=your_dashscope_api_key_here
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#
# EMBEDDING_PROVIDER=openai_compatible
# EMBEDDING_VENDOR=qwen
# EMBEDDING_MODEL=text-embedding-v4
# EMBEDDING_API_KEY=your_dashscope_api_key_here
# EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# -----------------------------------------------------------------------------
# DeepSeek LLM + mock embedding profile
# DeepSeek is used for chat completion here; retrieval stays offline.
# -----------------------------------------------------------------------------
# LLM_PROVIDER=openai_compatible
# LLM_VENDOR=deepseek
# LLM_MODEL=deepseek-chat
# LLM_API_KEY=your_deepseek_api_key_here
# LLM_BASE_URL=https://api.deepseek.com
#
# EMBEDDING_PROVIDER=mock
# EMBEDDING_VENDOR=mock
# EMBEDDING_MODEL=mock-embedding
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=
